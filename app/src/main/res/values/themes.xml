<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ClevertelVoIP" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_green_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorError">@color/error_red</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Login screen — no action bar -->
    <style name="Theme.ClevertelVoIP.Login" parent="Theme.ClevertelVoIP">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- In-call screen — full screen, over lock screen -->
    <style name="Theme.ClevertelVoIP.InCall" parent="Theme.ClevertelVoIP">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowShowWhenLocked">true</item>
        <item name="android:windowTurnScreenOn">true</item>
    </style>

</resources>
